# Leave DATABASE_URL unset for local development: the app falls back to PGlite,
# an embedded WASM build of Postgres that stores data in ./.pglite. No Docker,
# no daemon, same SQL as production.
#
# Set it to a real Postgres connection string (Neon, Supabase, RDS, ...) for
# staging and production.
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
